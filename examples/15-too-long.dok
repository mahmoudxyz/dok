// ─────────────────────────────────────────────────────────────
// dok-marketing.dok
// This entire document was written in dok.
// No Word. No HTML. No python-docx. Just dok.
// ─────────────────────────────────────────────────────────────

def section(title) {
  space(size: 12)
  box(fill: #1F3864, stroke: #1F3864) {
    bold(size: 13, color: white) { title }
  }
  space(size: 4)
}

def feature-row(label, description) {
  row {
    box(fill: #E8F4FD, stroke: #2196F3, rounded: true) {
      center { bold(color: #1F3864) { label } }
    }
    ->
    box(fill: #F8F9FA, stroke: #CCCCCC, rounded: true) {
      p { description }
    }
  }
  space(size: 4)
}

def metric(label, value) {
  box(fill: #F8F9FA, rounded: true) {
    center {
      color(value: gray) { label }
      bold(size: 22, color: #1F3864) { value }
    }
  }
}

def yes-badge {
  badge(fill: green, color: white) { "YES" }
}

def no-badge {
  badge(fill: red, color: white) { "NO" }
}

// ─────────────────────────────────────────────────────────────

doc(font: Calibri, size: 11) {

  header {
    right {
      italic(color: gray, size: 9) { "This document was written entirely in dok — no Word, no HTML, no code." }
    }
  }

  footer {
    center {
      p { color(value: gray, size: 9) { "Page " } page-number }
    }
  }

  page(margin: normal, paper: a4) {

    // ── Hero ───────────────────────────────────────────────────
    banner(fill: #1F3864, accent: gold, color: white) {
      center {
        bold(size: 22) { "dok" }
        p { "The output format for AI-generated documents." }
      }
    }

    space(size: 8)

    center {
      italic(color: gray) { "DOCX  ·  PDF  ·  HTML  ·  Email — one source, every format." }
    }

    space(size: 12)

    callout(fill: #FFF3CD, stroke: #FFC107, tail: top-left) {
      bold { "You are reading a dok document. " }
      "Every heading, table, box, banner, and badge on this page was produced from a plain text .dok file. No Word. No InDesign. No python-docx. Just dok compiled to DOCX."
    }

    // ── Why dok ────────────────────────────────────────────────
    section(title: "Why dok exists")

    p {
      "Ask an AI to generate a Word document today and one of three things happens: "
      bold { "it writes python-docx code that breaks on anything non-trivial, " }
      "it writes Markdown that loses all formatting on conversion, or "
      bold { "it hallucinates OOXML directly and produces a corrupt file." }
    }

    code {
  """
  p = doc.add_paragraph()
  pPr = p._p.get_or_add_pPr()
  bidi = OxmlElement('w:bidi')
  pPr.insert(0, bidi)
  """
}

    p {
      "Dok fixes that. The grammar is small enough to fit in a system prompt. "
      "There is one way to express each thing — no ambiguity for AI to hallucinate into. "
      "Errors are structured and self-correcting. The AI outputs dok. The compiler handles everything below."
    }

    p {
      "Ask an AI to generate a Word document today and one of three things happens: "
      bold { "it writes python-docx code that breaks on anything non-trivial, " }
      "it writes Markdown that loses all formatting on conversion, or "
