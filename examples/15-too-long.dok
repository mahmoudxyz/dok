      bold { "it hallucinates OOXML directly and produces a corrupt file." }
    }

    code {
  """
  p = doc.add_paragraph()
  pPr = p._p.get_or_add_pPr()
  bidi = OxmlElement('w:bidi')
  pPr.insert(0, bidi)
  """
}

    p {
      "Dok fixes that. The grammar is small enough to fit in a system prompt. "
      "There is one way to express each thing — no ambiguity for AI to hallucinate into. "
      "Errors are structured and self-correcting. The AI outputs dok. The compiler handles everything below."
